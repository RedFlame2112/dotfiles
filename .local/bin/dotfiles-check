#!/usr/bin/env bash
set -uo pipefail

failures=0
run() {
  printf '\n==> %s\n' "$1"
  shift
  if ! "$@"; then
    failures=$((failures + 1))
  fi
}

run "Zsh syntax" zsh -n "$HOME/.zshrc"
run "Neovim startup" nvim --headless +qa

if command -v home-manager >/dev/null 2>&1; then
  run "Home Manager evaluation" home-manager build --no-out-link
fi

if command -v shellcheck >/dev/null 2>&1; then
  mapfile -t scripts < <(find "$HOME/.local/share/bin" -maxdepth 1 -type f -name '*.sh' -print)
  if ((${#scripts[@]})); then
    run "Shell scripts" shellcheck "${scripts[@]}"
  fi
fi

if ((failures)); then
  printf '\n%d check(s) failed.\n' "$failures" >&2
  exit 1
fi

printf '\nAll available dotfile checks passed.\n'
